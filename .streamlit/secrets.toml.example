# ---------------------------------------------------------------------------
# Streamlit secrets template for "At 10,000 Feet" maturity assessment app.
#
# Copy this file to `.streamlit/secrets.toml` and fill in the real values.
# NEVER commit the real secrets.toml to version control.
#
# If the [gcp_service_account] block or sheet_id is missing, the app falls
# back to writing submissions to ./submissions_local.csv (local dev only).
# ---------------------------------------------------------------------------

# The Google Sheet ID (the long string in the sheet URL between /d/ and /edit).
sheet_id = "your-google-sheet-id-here"

# Service account credentials JSON, field-by-field.
# Create this in Google Cloud Console → IAM → Service Accounts → Keys (JSON).
[gcp_service_account]
type = "service_account"
project_id = "your-project-id"
private_key_id = "your-private-key-id"
# Keep the literal \n escapes inside the quotes exactly as they appear in the JSON.
private_key = "-----BEGIN PRIVATE KEY-----\nYOUR_KEY_LINE_1\nYOUR_KEY_LINE_2\n-----END PRIVATE KEY-----\n"
client_email = "your-service-account@your-project-id.iam.gserviceaccount.com"
client_id = "your-client-id"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/your-service-account%40your-project-id.iam.gserviceaccount.com"
universe_domain = "googleapis.com"
